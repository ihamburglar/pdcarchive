# PostgreSQL connection (local dev)
DATABASE_URL=postgres://pdcarchive:pdcarchive@localhost:5432/pdcarchive?sslmode=disable
DB_MAX_OPEN_CONNS=12
DB_MAX_IDLE_CONNS=5

# HTTP server (Railway injects PORT automatically)
PORT=8080

# Upstream Socrata source
SOURCE_BASE_URL=https://data.wa.gov
SOCRATA_APP_TOKEN=

# Daily background sync time (scheduler runs inside serve process)
SYNC_TIME=02:00
SYNC_TIMEZONE=America/Los_Angeles

# Upstream fetch pacing: records per request and random delay between requests
SYNC_PAGE_SIZE=1000
SYNC_PAGE_INTERVAL_MIN=5s
SYNC_PAGE_INTERVAL_MAX=15s

# Admin login (backend only — API remains public)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
SESSION_SECRET=generate-a-random-string-here

# Set to "release" in production (Railway)
GIN_MODE=debug

# Optional: explicit path to env file (default searches cwd and parents)
# ENV_FILE=/path/to/.env
