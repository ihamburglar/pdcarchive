# PostgreSQL connection (local dev via docker-compose)
DATABASE_URL=postgres://pdcarchive:pdcarchive@localhost:5432/pdcarchive?sslmode=disable

# HTTP server (Railway injects PORT automatically)
PORT=8080

# Upstream Socrata source
SOURCE_BASE_URL=https://data.wa.gov
SOCRATA_APP_TOKEN=

# Comma-separated Socrata resource IDs to mirror
DATASETS=kv7h-kjye,tijg-9zyp,7qr9-q2c9,3h9x-7bvm,3r6b-hsaa,d2ig-r3q4

# Background sync interval (scheduler runs inside serve process)
SYNC_INTERVAL=24h

# Admin login (backend only — API remains public)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
SESSION_SECRET=generate-a-random-string-here

# Set to "release" in production (Railway)
GIN_MODE=debug

# Optional: explicit path to env file (default searches cwd and parents)
# ENV_FILE=/path/to/.env
